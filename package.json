{
  "name": "focus-tracker",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "make-icon": "node scripts/make-icon.js"
  },
  "dependencies": {
    "electron-store": "8"
  },
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "latest",
    "sharp": "latest"
  },
  "build": {
    "appId": "com.focustracker.app",
    "productName": "FocusTracker",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "FocusTracker"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**",
      "assets/**",
      "package.json",
      "node_modules/**"
    ]
  }
}
